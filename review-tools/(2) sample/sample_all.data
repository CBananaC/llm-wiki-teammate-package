        "commands": [
          {
            "title": "嚴禁對漳泉民人預存歧視",
            "summary": "皇帝指示，不論何處民人，從賊者即按名駢戮；但若漳、泉民人與鄉勇能應募拒賊、出力防守，即屬良民，應加獎賞。不可預存歧視而稍露形跡，以免漳州民人心生惶懼而另滋事端。",
            "quote": "若漳、泉民人鄉勇，果能應募拒賊，出力堵御防守，即系良民，自應加以獎賞，不應預存岐視，稍露形跡，轉致漳民心生惶懼，別滋事端，於內地大有關係。",
            "target": [
              "常青"
            ],
            "responses": [
              {
                "doc_id": "奏117",
                "official": "黃仕簡",
                "sendAr": "1787/01/27",
                "subtitle": "申明大義並給予獎賞",
                "desc": "黃仕簡報告他到臺灣後即申明大義，對協同官兵堵禦殺賊之漳、泉及粵省義民給予獎賞，使其倍加奮激。",
                "quote": "凡攻擾所到，多有漳、泉暨粵省義民協同官兵堵禦殺賊，奴才到臺即申明大義，給與獎賞，人人倍加奮激，志切同仇，業經附摺奏聞在案。",
                "__added": false
              }
            ],
            "__added": false,
            "__eaEvId": null
          },
          {
            "title": "各路兵丁到齊後併力夾攻",
            "summary": "皇帝告誡閩人性情慓輕，零星打仗易致挫失而餒軍心。命令黃仕簡與任承恩務必等待各路兵丁到齊，約定日期同時併力夾攻，鎮定持重，不可張皇。",
            "quote": "著傳諭黃仕簡、任承恩，務須各路兵丁到齊，約會日期，同時併力夾攻，自無難一舉事。該督等總須鎮定持重，不可稍涉張皇。",
            "target": [
              "黃仕簡",
              "任承恩"
            ],
            "responses": [
              {
                "doc_id": "奏117",
                "official": "黃仕簡",
                "sendAr": "1787/01/27",
                "subtitle": "因兵未齊先守後攻並收復諸羅",
                "desc": "黃仕簡說明初到臺灣時因內地官兵未齊，先派兵保固府城，待官兵續到後即分遣南北兩路進剿，並於二十四日由柴大紀收復諸羅縣城。",
                "quote": "奴才初到臺郡，因內地官兵尚未到齊，隨將現到兵丁派撥四郊要路添防，加緊堵截，保固府城...嗣官兵續到，隨同日分遣前赴南、北二路，並力進剿。二十四日據赴北路總兵柴大紀報到克復諸羅縣城池",
                "__added": false
              }
            ],
            "__added": false,
            "__eaEvId": null
          },
          {
            "title": "駐防滿兵不可輕舉妄動",
            "summary": "皇帝指出福建駐防滿兵並非健銳火器營，且調撥出征徒增地方繁費，省城重地亦需留兵彈壓，命令恆瑞處以鎮靜，斷不可輕舉妄動。",
            "quote": "著傳諭恆瑞，尤宜處以鎮靜，斷不可輕舉妄動，徒勞無益。",
            "target": [
              "恆瑞"
            ],
            "responses": [],
            "__added": false,
            "__eaEvId": null
          },
          {
            "title": "鄰省兵力密為佈置不可驚眾",
            "summary": "皇帝認為此時似不需要鄰省接濟兵力，但廣東、浙江二省預備撥兵策應亦無不可，惟必須不動聲色、秘密佈置，不可稍微矜張以致驚動輿論。",
            "quote": "此時似可無需鄰省接濟兵力，然備撥亦可，總宜不動聲色，密為佈置，不可稍涉矜張，驚動衆聽。此一節並傳諭孫士毅、琅玕一體遵照妥辦。",
            "target": [
              "孫士毅",
              "琅玕"
            ],
            "responses": [],
            "__added": false,
            "__eaEvId": null
          },
          {
            "title": "傳諭柴大紀努力剿捕並優敘",
            "summary": "皇帝要求常青等轉告柴大紀，務必努力剿捕，若能保守臺灣並迅速收復諸羅、彰化二縣，皇帝必將從優獎勵議敘。",
            "quote": "著常青等傳諭該鎮，務須努力剿捕，倘能得守臺灣等處，收復諸、彰二縣，迅速蕆事，朕必加以獎勵，從優議敘。",
            "target": [
              "常青",
              "徐嗣曾",
              "恆瑞"
            ],
            "responses": [],
            "__added": false,
            "__eaEvId": null
          },
          {
            "title": "事定後查明嚴參地方文武失察",
            "summary": "皇帝質疑臺地會匪興起數年、頃刻聚集數千人，地方文武平日竟然毫無覺察。命令常青於戰事平定後，查明嚴加參奏示儆，但強調此非目前急務，當前以速剿賊匪為要。",
            "quote": "至臺地會匪系何會？興有幾年？頃刻之間即以聚至數千，蔓延滋擾，劫縣戕官。該地方文武平日所司何事，豈竟漫無覺察？並著常青於事定後，查明嚴參示做，但非目前急務。此時惟當鎮內地，速剿賊匪爲要。",
